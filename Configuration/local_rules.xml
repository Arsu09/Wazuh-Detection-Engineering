<group name="local,syslog,sshd,">
  <rule id="100001" level="10">
    <if_matched_sid>5712</if_matched_sid>
    <same_source_ip />
    <description>Possible SSH Brute Force Attack: Multiple failed logins from same IP.</description>
  </rule>

  <rule id="100002" level="7">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4720$</field>
    <description>New user account created on Windows.</description>
  </rule>
</group>
